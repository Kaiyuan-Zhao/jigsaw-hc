NODE_ENV=production
PORT=8787
FRONTEND_URL=https://www.example.com
GAME_ALLOWED_ORIGINS=https://www.example.com,https://example.com
PIECE_DB_PATH=/data/pieces.sqlite
HCAUTH_CLIENT_ID=your_client_id
HCAUTH_CLIENT_SECRET=your_client_secret
HCAUTH_REDIRECT_URI=https://api.example.com/auth/callback
HCAUTH_SCOPES=openid profile email name slack_id verification_status
SESSION_SECRET=replace_with_random_hex
CLAIM_TOKEN_SECRET=replace_with_random_hex
CLAIM_TOKEN_TTL_SECONDS=180
